# ?  A Basic setup and initial information to run the backend

PORT=4001
# any backend port that you are comfortable to run the server.. 


#* better auth secret key
BETTER_AUTH_SECRET= XXXXXXXXXXXXXXXXXXXX 
# go to better auth and bring generate the secrete and replace it


# * PostgresSQL Database..
DATABASE_URL= "example.neonDB/foodHub/backend"
# your comfortable postgresSql database like to store all information   



#* Public URL of THIS API (Express) — must match PORT in local dev. No trailing slash.
BETTER_AUTH_URL=http://localhost:4001
# Production: https://your-backend.vercel.app



#* Browser origin of your Next app only (CORS + Better Auth trustedOrigins). No trailing slash.
FRONTEND_URL=http://localhost:3000
# Production: https://your-frontend.vercel.app
# Multiple: FRONTEND_URL=http://localhost:3000,https://your-frontend.vercel.app
